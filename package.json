{
  "name": "jsxgraph-markdown",
  "displayName": "JSXGraph in Markdown",
  "description": "Render JSXGraph diagrams in Markdown and provide JavaScript language features for jsxgraph code blocks.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.100.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "JSXGraph Markdown executes JavaScript from trusted Markdown documents in the preview."
    }
  },
  "categories": [
    "Visualization",
    "Programming Languages"
  ],
  "keywords": [
    "jsxgraph",
    "markdown",
    "diagram",
    "visualization"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./node_modules/jsxgraph/distrib/jsxgraph.css",
      "./media/preview.css"
    ],
    "markdown.previewScripts": [
      "./node_modules/jsxgraph/distrib/jsxgraphcore.js",
      "./media/preview.js"
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc --noEmit -p ./",
    "test": "npm run compile && node --test"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.100.0",
    "markdown-it": "^14.3.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "jsxgraph": "^1.12.2"
  }
}
