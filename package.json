{
  "name": "jsxgraph-markdown",
  "displayName": "JSXGraph Markdown",
  "description": "Render JSXGraph diagrams in Markdown and provide JavaScript language features for jsxgraph code blocks.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages"
  ],
  "keywords": [
    "jsxgraph",
    "markdown",
    "diagram",
    "visualization"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc --noEmit -p ./"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.8.3"
  }
}

